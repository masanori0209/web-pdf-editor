{
  "name": "pdf-editor",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm && tsc -b && vite build",
    "build:wasm": "cd crates/pdf-wasm && wasm-pack build --target web --out-dir ../../src/wasm/pkg",
    "lint": "eslint .",
    "preview": "vite preview",
    "setup:fonts": "node scripts/setup-fonts.mjs",
    "setup:pdfium": "node scripts/setup-pdfium.mjs",
    "setup": "npm run setup:fonts && npm run setup:pdfium && npm run build:wasm",
    "postinstall": "node -e \"const fs=require('fs'); if(!fs.existsSync('public/fonts/NotoSansJP-VF.ttf')) console.log('Run npm run setup:fonts'); if(!fs.existsSync('public/pdfium/pdfium.wasm')) console.log('Run npm run setup:pdfium'); if(!fs.existsSync('src/wasm/pkg/pdf_wasm.js')) console.log('Run npm run build:wasm');\"",
    "test:e2e": "node e2e/generate-fixtures.mjs && playwright test",
    "test:e2e:journey": "node e2e/generate-fixtures.mjs && playwright test e2e/scenarios/pattern-g-full-journey.spec.ts",
    "test:e2e:patterns": "node e2e/generate-fixtures.mjs && playwright test e2e/scenarios/",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@fontsource/noto-sans-jp": "^5.2.5",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.0.379",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
